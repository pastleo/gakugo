    "@types/react-dom": "^19.2.3",
    "daisyui": "^5.5.19",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "prettier": "3.6.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}
